{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "assigneesFromCodeOwners": true,
  "extends": [
    "schedule:nonOfficeHours"
  ],
  "dependencyDashboard": true,
  "enabledManagers": [
    "pep621"
  ],
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": [
      "at any time"
    ]
  },
  "packageRules": [
    {
      "matchPackageNames": [
        "python"
      ],
      "enabled": false
    }
  ],
  "timezone": "America/New_York",
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ],
    "schedule": [
      "at any time"
    ]
  }
}